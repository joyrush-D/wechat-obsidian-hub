{
  "name": "wechat-obsidian-hub",
  "version": "0.3.0",
  "description": "WeChat Obsidian Hub plugin",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "node esbuild.config.mjs production",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "verify": "npm run typecheck && npm run test && npm run build",
    "verify:e2e": "echo 'Run on Mac: scp scripts/release-verify.mjs mac:/tmp/ && ssh mac \"/opt/homebrew/bin/node /tmp/release-verify.mjs\"'"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "builtin-modules": "^4.0.0",
    "esbuild": "^0.24.0",
    "obsidian": "latest",
    "typescript": "^5.5.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "^2.0.41",
    "ai": "^6.0.168",
    "fflate": "^0.8.2",
    "fzstd": "^0.1.1",
    "sql.js": "^1.11.0",
    "zod": "^4.3.6"
  }
}
